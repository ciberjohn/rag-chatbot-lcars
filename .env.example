# Claude / Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# ChromaDB bearer token (generate with: openssl rand -hex 32)
CHROMA_AUTH_TOKEN=your-chroma-token-here

# Admin token for the /api/reindex endpoint (generate with: openssl rand -hex 32)
ADMIN_TOKEN=your-admin-token-here

# Optional overrides
MODEL=claude-haiku-4-5-20251001
LOG_LEVEL=INFO
SYNC_INTERVAL_MINUTES=30
MAX_SEARCH_RESULTS=5
